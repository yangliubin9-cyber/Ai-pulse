# ai-pulse 配置样例（铁律七：每字段注释；敏感字段标 # SECRET 且默认留空）
# 跨模式映射：SCREAMING_SNAKE_CASE ⇄ helm values camelCase ⇄ GitLab CI variables 同名
# 例外映射（历史命名）：DB_* ⇄ helm 的 database.*（见 03-Services/database.md 标准字段）

# ── 镜像（docker-compose.md 客户可变项） ─────────────────
IMAGE_REGISTRY=registry.example.com       # 镜像仓库地址（客户可改为私有 registry）
IMAGE_TAG=                        # 部署版本 = git tag（必填，禁 latest）

# ── 基本 ────────────────────────────────────────────────
ENV=dev                           # 环境标识：dev | staging | prod
LOG_LEVEL=INFO                    # 日志级别：DEBUG | INFO | WARNING | ERROR
TZ=UTC                            # 容器时区：全栈统一 UTC，仅展示层转换（database.md 时区约定）

# ── 端口（项目端口段偏移 +0..+9，分配表写入项目 .agent.md） ──
FRONTEND_PORT=17010   # 端口段 +0
BACKEND_PORT=17011     # 端口段 +1

# ── Database（启用则保留；标准字段见 03-Services/database.md） ──
DATABASE_PROVIDER=postgres        # postgres | mysql | oracle | tidb
DB_HOST=postgres                  # compose 内为服务名；客户自管 DB 时改为其地址
DB_PORT=17012               # 端口段 +2（容器内仍为 5432）
DB_USER=ai-pulse
DB_PASSWORD=                      # SECRET
DB_NAME=ai-pulse
DB_POOL_SIZE=10
DB_SSL_MODE=prefer

# ── Cache（启用则保留；字段见 03-Services/cache.md） ──
CACHE_PROVIDER=redis
CACHE_HOST=redis
CACHE_PORT=17013         # 端口段 +3
CACHE_PASSWORD=                   # SECRET

# ── 翻译（离线英文->中文机器翻译，入库时翻译存 title_zh / summary_zh） ──
TRANSLATION_ENABLED=true          # 是否在入库时翻译英文资讯为中文
TRANSLATION_PROVIDER=local        # local = argostranslate（本地离线，无需外部 API/key）
TRANSLATION_TARGET_LANG=zh        # 目标语言代码

# ── 可观测性（observability-baseline.md §6，按需补全量清单） ──
OTEL_TRACES_ENABLED=false                 # 链路追踪开关（默认关）
OTEL_EXPORTER_OTLP_METRICS_ENABLED=false  # OTLP 指标导出开关（默认关，不主动外联）
OTEL_TRACES_SAMPLER_ARG=0.1               # 采样率

# TODO(bootstrap): 启用 object-storage / vector-db / message-queue 分类时按 03-Services/<分类>.md 补字段
